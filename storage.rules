rules_version = '2';

// Firebase Storage rules for Kaya.
//
// Scope today: the Moments photo feed. Photos live at
//   families/{f}/posts/{p}/{photoId}/{size}.jpg
// with size in { thumb | feed | full } and only family members can
// read or write within their own family's tree. The Firestore post
// doc carries the matching download URLs; deleting the post triggers
// best-effort deletion of these blobs from client code.
//
// Image-only upload, 10 MB cap per variant — that's the post-resize
// budget (the 25 MB raw cap in `photoUpload.ts` is the pre-resize
// guard, applied client-side before the canvas downscale).

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserProfile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToFamily(familyId) {
      return isSignedIn() && getUserProfile().familyId == familyId;
    }

    // ── Moments · post photos ──────────────────────────────────
    match /families/{familyId}/posts/{postId}/{photoId}/{file} {
      allow read: if belongsToFamily(familyId);
      // Photos (image, <10 MB) + video clips (<100 MB, 2026-05-21). A
      // video's poster still is an image variant under the same path.
      allow write: if belongsToFamily(familyId) && (
        (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
        || (request.resource.contentType.matches('video/.*') && request.resource.size < 100 * 1024 * 1024)
      );
      allow delete: if belongsToFamily(familyId);
    }

    // ── Keepsake · album photos ────────────────────────────────
    // Per-album visibility (parents-only, custom subset) is enforced
    // at the Firestore layer when the user reads the photo doc —
    // without the doc they don't get the download URL, so Storage
    // can stay family-scoped here without leaking restricted content.
    match /families/{familyId}/albums/{albumId}/{photoId}/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if belongsToFamily(familyId);
    }

    // ── Household → Purchase receipts (2026-05-19) ─────────────
    // One receipt photo per purchase request, uploaded during
    // reconcile. Stored at:
    //   families/{f}/purchaseRequests/{requestId}/receipt/{photoId}.jpg
    // Same family-scope as the post/album surfaces — anyone in the
    // family can upload (helper attaches, parent reviews). Receipts
    // are bigger than thumbs but smaller than full-resolution Moments
    // (~1600px long edge after the client-side downscale).
    match /families/{familyId}/purchaseRequests/{requestId}/receipt/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if belongsToFamily(familyId);
    }

    // ── Kaya Wealth · asset documents (PR3, 2026-06-01) ────────
    // Scanned + enhanced documents (title deeds, policies, surveys…)
    // attached to a wealth asset, at:
    //   families/{f}/wealth/{assetId}/{docId}.jpg
    // PARENT-ONLY — the vault is a parent space. The download URL is only
    // discoverable via the asset doc, which is itself visibility-gated in
    // firestore.rules (personal assets' docs stay hidden from the
    // co-parent there). Image-only, <10 MB after the client-side enhance.
    match /families/{familyId}/wealth/{assetId}/{file} {
      allow read: if belongsToFamily(familyId) && getUserProfile().role == 'parent';
      allow write: if belongsToFamily(familyId) && getUserProfile().role == 'parent'
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if belongsToFamily(familyId) && getUserProfile().role == 'parent';
    }

    // ── Kaya Business → stock-take + product/project photos (2026-05-21) ──
    // One folder per business. Family-scoped (parent + owner kid both upload).
    //   families/{f}/businesses/{businessId}/photos/{photoId}.jpg
    match /families/{familyId}/businesses/{businessId}/photos/{file} {
      allow read: if belongsToFamily(familyId);
      // Photos (image, <10 MB) + short stock-take video clips (<50 MB).
      allow write: if belongsToFamily(familyId)
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
          || (request.resource.contentType.matches('video/.*') && request.resource.size < 50 * 1024 * 1024)
        );
      allow delete: if belongsToFamily(familyId);
    }

    // ── Kids Projects → product/build photos (2026-05-21) ──
    //   families/{f}/projects/{projectId}/photos/{photoId}.jpg
    match /families/{familyId}/projects/{projectId}/photos/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if belongsToFamily(familyId);
    }

    // ── Dine Out → per-venue photo gallery (2026-05-23) ──
    // Photos taken at a place, kept with the venue (and optionally also
    // shared to Moments — same blob, the post just references its URL).
    //   families/{f}/venues/{venueId}/{photoId}/{size}.jpg
    match /families/{familyId}/venues/{venueId}/{photoId}/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if belongsToFamily(familyId);
    }

    // ── Kids' Workplan → "proof for points" media (2026-05-23) ──
    // One folder per proof-required task per day:
    //   families/{f}/children/{childId}/workplanProofs/{date}_{itemId}/{photoId}.<ext>
    // The KID uploads their own proof here directly (then the server
    // writes the Firestore proof doc + awards). Family-scoped so parents
    // can also attach/replace and everyone can view in the review feed.
    // Photo (image, <10 MB, post-downscale) OR a short video clip
    // (<60 MB raw) — matching the 60 MB cap in workplanProofUpload.ts.
    match /families/{familyId}/children/{childId}/workplanProofs/{folder}/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId) && (
        (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
        || (request.resource.contentType.matches('video/.*') && request.resource.size < 60 * 1024 * 1024)
      );
      allow delete: if belongsToFamily(familyId);
    }

    // ── Kaya Games → Real-World challenge proofs (2026-05-31) ──
    // The kid uploads a photo proving a Real-World challenge; it becomes a
    // PENDING gamePlay a parent approves in /games/approvals. Family-scoped,
    // image-only, < 10 MB (post-downscale). Path:
    //   families/{f}/children/{childId}/gameProofs/{gameId}/{photoId}.jpg
    match /families/{familyId}/children/{childId}/gameProofs/{gameId}/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if belongsToFamily(familyId);
    }

    // ── Kaya Sparks → item photos (2026-05-27) ──
    // Per-item photo gallery for the 4 capture areas (school projects,
    // home projects, achievements, sports subscriptions). Family-scoped
    // — the kid captures their own work; parents + helpers can also
    // upload on the kid's behalf. Three sizes (thumb / feed / full) per
    // photo via processPhotoForUpload(), 10 MB cap each. Path:
    //   families/{f}/sparks/{itemId}/{photoId}/{size}.jpg
    match /families/{familyId}/sparks/{itemId}/{photoId}/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if belongsToFamily(familyId);
    }

    // ── Kaya Sparks → Home Practice Materials (2026-05-28) ──
    // Reference docs uploaded by parents (or helpers with sparks-act)
    // and read by kids during revisions. Family-scoped — anyone in the
    // family can read; the per-kid sharing gate is applied at the
    // Firestore + UI layer via `shared_with`. Write is intentionally
    // wider than Sparks photos: PDFs (mostly), Office docs, images.
    // 25 MB cap matches the messaging-document cap.
    //   families/{f}/sparks_materials/{materialId}/{file}
    match /families/{familyId}/sparks_materials/{materialId}/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId)
        && request.resource.size < 25 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*')
          || request.resource.contentType.matches('application/vnd.ms-.*')
          || request.resource.contentType.matches('application/msword')
          || request.resource.contentType.matches('text/.*')
        );
      allow delete: if belongsToFamily(familyId);
    }

    // ── Household → Subscription receipts (2026-05-27) ──
    // Phase 1 ships ONLY Property-linked Manual subscription receipts —
    // rent, BC fees, land rates, borehole servicing. These are receipts
    // the parent OCRs + forwards to Wealth / Property Manager / email
    // (WhatsApp Soon). Everything else (Netflix etc.) waits for the
    // full Storage rollout in Phase 2 per spec §3.8.
    //
    // Path: families/{f}/subscriptions/{subId}/receipts/{file}
    //
    // Family-scoped — anyone in the family can upload (helper captures,
    // parent reviews). The "Property only" gate is enforced at the
    // Firestore + UI layer; once a blob is here it's just a file, and
    // the schema requires a parent receipt doc to mark + reference it.
    // Image (≤ 10 MB) or PDF (≤ 10 MB).
    match /families/{familyId}/subscriptions/{subId}/receipts/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId)
        && request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
      allow delete: if belongsToFamily(familyId);
    }

    // ── Messaging → attachments (2026-05-24) ──
    // One folder per thread:
    //   families/{f}/messages/{threadId}/{fileId}.<ext>
    // Family-scoped read (the Firestore message doc holds the URL, and
    // thread membership gates who can read that doc). Write: any family
    // member — photo (image <10 MB, downscaled), video (<50 MB), voice
    // note (audio <25 MB), or document (application/* or text/* <25 MB).
    match /families/{familyId}/messages/{threadId}/{file} {
      allow read: if belongsToFamily(familyId);
      allow write: if belongsToFamily(familyId) && (
        (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
        || (request.resource.contentType.matches('video/.*') && request.resource.size < 50 * 1024 * 1024)
        || (request.resource.contentType.matches('audio/.*') && request.resource.size < 25 * 1024 * 1024)
        || ((request.resource.contentType.matches('application/.*') || request.resource.contentType.matches('text/.*')) && request.resource.size < 25 * 1024 * 1024)
      );
      allow delete: if belongsToFamily(familyId);
    }
  }
}
