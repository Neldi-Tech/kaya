# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
# Use a custom subdomain (e.g. auth.<your-domain>) for branding;
# the default <your-project>.firebaseapp.com still works as a fallback.
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=auth.your-domain.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
# Firebase Cloud Messaging (web push). Generate in Firebase Console:
# Project Settings → Cloud Messaging → Web Push certificates → Generate key pair.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-public-key

# Google Identity Services (Sign In With Google)
# OAuth 2.0 Web client ID from the same GCP project as Firebase.
# GCP Console → APIs & Services → Credentials → Web client (auto created by Google Service)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Firebase Admin SDK (server-side) ─────────────────────────────────
# Required for FCM web-push delivery (e.g. /api/push — workplan ad-hoc
# notify). Generate a service-account JSON in GCP Console:
#   IAM & Admin → Service Accounts → (create or pick) → Keys → Add key (JSON)
# Then either:
#   (a) point GOOGLE_APPLICATION_CREDENTIALS at the file path (local dev), or
#   (b) split the JSON into the 3 env vars below (Vercel / managed hosts).
# On Vercel, paste the private key as a SINGLE LINE with literal `\n`
# escapes — the admin init unescapes them at runtime.
# If none of these are set, /api/push gracefully no-ops and only the
# in-app notification bell fires (still functional, just no device push).
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-key-here\n-----END PRIVATE KEY-----\n"
