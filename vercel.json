{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/perf-digest",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/market-quotes",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/business-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/business-hp",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/pulse-generate",
      "schedule": "5 21 * * *"
    },
    {
      "path": "/api/cron/pulse-rotate",
      "schedule": "55 20 * * 0"
    },
    {
      "path": "/api/cron/pulse-scan",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cycle-advancer",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/wealth-advisor",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/coppa-retention",
      "schedule": "30 3 * * *"
    }
  ]
}
