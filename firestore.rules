rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Closed-beta access (2026-05-24) ────────────────────────────
    // Email-keyed gates for the invite-only launch. `callerEmail()` is
    // the signed-in user's email claim (present for Google + email/
    // password). config/beta holds the runtime switches; a missing doc
    // is treated as CLOSED (safe default), so the gate fails shut.
    function betaConfig() {
      return get(/databases/$(database)/documents/config/beta).data;
    }
    function publicSignupOpen() {
      return exists(/databases/$(database)/documents/config/beta)
        && betaConfig().publicSignupOpen == true;
    }
    function callerEmail() {
      return request.auth.token.email;
    }
    function isAllowlisted() {
      return isSignedIn()
        && callerEmail() != null
        && exists(/databases/$(database)/documents/allowlist/$(callerEmail()));
    }
    function isOperator() {
      return isSignedIn()
        && callerEmail() != null
        && exists(/databases/$(database)/documents/operators/$(callerEmail()));
    }

    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToFamily(familyId) {
      return isSignedIn() && getUserProfile().familyId == familyId;
    }

    function isParentInFamily(familyId) {
      return belongsToFamily(familyId) && getUserProfile().role == 'parent';
    }

    function isParentOrHelper(familyId) {
      let profile = getUserProfile();
      return belongsToFamily(familyId) && (profile.role == 'parent' || profile.role == 'helper');
    }

    // True if the calling user is the kid linked to `kidId` in `familyId`.
    // Helpers and parents return false here — use `isParentInFamily` /
    // `isParentOrHelper` for those branches.
    function isThisKid(familyId, kidId) {
      let profile = getUserProfile();
      return belongsToFamily(familyId)
        && profile.role == 'kid'
        && profile.childId == kidId;
    }

    // ── Helper scope (per-family HelperLink) ──────────────────────
    // True when the caller is a helper in `familyId` AND their
    // HelperLink doc lists `kidId` in its `kidIds` array AND status is
    // active. Per-kid scope only — combine with `helperHasModule()` to
    // also require a specific module flag.
    function helperCanActOnKid(familyId, kidId) {
      return belongsToFamily(familyId)
        && getUserProfile().role == 'helper'
        && exists(/databases/$(database)/documents/families/$(familyId)/helpers/$(request.auth.uid))
        && get(/databases/$(database)/documents/families/$(familyId)/helpers/$(request.auth.uid)).data.status == 'active'
        && get(/databases/$(database)/documents/families/$(familyId)/helpers/$(request.auth.uid)).data.kidIds.hasAny([kidId]);
    }

    // Module access — two tiers (view vs act). Canonical source is
    // `HelperLink.moduleAccess` (map keyed by kid-module id, each
    // value `{view, act}`). Docs written before the moduleAccess
    // field existed have only the legacy `modules` array — those
    // entries are treated as full view+act. Either function returns
    // false for non-helpers, paused helpers, and helpers with no
    // link doc (legacy-helper escape hatch handles those separately).
    function _helperLink(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)/helpers/$(request.auth.uid)).data;
    }
    function _helperHasModuleTier(familyId, moduleId, tier) {
      return belongsToFamily(familyId)
        && getUserProfile().role == 'helper'
        && exists(/databases/$(database)/documents/families/$(familyId)/helpers/$(request.auth.uid))
        && _helperLink(familyId).status == 'active'
        && (
          // New shape: moduleAccess map + the tier flag is true.
          (
            'moduleAccess' in _helperLink(familyId)
            && moduleId in _helperLink(familyId).moduleAccess
            && _helperLink(familyId).moduleAccess[moduleId][tier] == true
          )
          // Legacy shape: only `modules` array — treat as view+act.
          || (
            !('moduleAccess' in _helperLink(familyId))
            && _helperLink(familyId).modules.hasAny([moduleId])
          )
        );
    }
    function helperCanViewModule(familyId, moduleId) {
      return _helperHasModuleTier(familyId, moduleId, 'view');
    }
    function helperCanActOnModule(familyId, moduleId) {
      return _helperHasModuleTier(familyId, moduleId, 'act');
    }
    // Back-compat alias for older call sites still in this file —
    // both are write-tier checks. New code should call
    // `helperCanActOnModule` directly.
    function helperHasModule(familyId, moduleId) {
      return helperCanActOnModule(familyId, moduleId);
    }

    // Convenience: act-tier check for a composite "{parent}:{sub}" key
    // OR the bare parent grant. The parent grant means "everything in
    // this module" (e.g. granting `household` covers all the pantry
    // sub-pages). Used by collection rules like /staples, /suppliers
    // etc. to gate per-sub without requiring the parent to enumerate.
    function helperCanActOnSub(familyId, parentKey, subId) {
      return helperCanActOnModule(familyId, parentKey + ':' + subId)
          || helperCanActOnModule(familyId, parentKey);
    }

    // Legacy-helper escape hatch: helpers who joined BEFORE the
    // HelperLink rollout have no doc under /families/{f}/helpers/{uid}.
    // We don't want to lock them out, so fall back to the old
    // family-wide helper permission until the parent re-adds them
    // through Settings → Helpers (which writes a HelperLink and flips
    // them onto the scoped path). True ONLY when no HelperLink exists.
    function isLegacyHelperWithoutLink(familyId) {
      return belongsToFamily(familyId)
        && getUserProfile().role == 'helper'
        && !exists(/databases/$(database)/documents/families/$(familyId)/helpers/$(request.auth.uid));
    }

    // ── Users ──────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile, OR any profile attached to
      // the same family. The cross-family lookup is what makes the
      // @mention picker, rating/award notification routing, and family
      // tree work — without it `getFamilyMembers` silently fails and
      // none of those features can find anyone besides the caller.
      // The `get()` costs one extra read per query but is bounded:
      // the picker only loads it once per session.
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || (
          resource.data.familyId != null
          && resource.data.familyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId
        )
      );
      // Users can create their own profile (during onboarding).
      // Parents can additionally create a helper UserProfile in
      // THEIR family — this is what the "Add helper" flow in Settings
      // does after spinning up the helper's auth user via the
      // secondary-app pattern (the parent's session is the only auth
      // context still alive at write-time).
      allow create: if isSignedIn() && (
        request.auth.uid == userId
        || (
          request.resource.data.role == 'helper'
          && request.resource.data.familyId ==
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent'
        )
      );
      // Users can update their own profile
      allow update: if isSignedIn() && request.auth.uid == userId;

      // FCM registration tokens — one doc per device/browser, keyed by
      // the token string. Only the owner can read/write their own
      // tokens; the server (admin SDK) bypasses these rules when
      // sending pushes.
      match /fcmTokens/{token} {
        allow read, write, delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ── Families ───────────────────────────────────
    match /families/{familyId} {
      // Family members can read
      allow read: if belongsToFamily(familyId);
      // Closed beta (2026-05-24): a signed-in user may create a family
      // only when public sign-up is open (launch mode) OR their email is
      // on the early-access allowlist. Existing families are unaffected —
      // their members already carry a familyId and never hit create.
      allow create: if isSignedIn() && (publicSignupOpen() || isAllowlisted());
      // Only parents can update family settings
      allow update: if isParentInFamily(familyId);

      // Allow reading family by invite code (for joining)
      allow list: if isSignedIn();

      // ── Children ─────────────────────────────────
      match /children/{childId} {
        allow read: if belongsToFamily(familyId);
        allow create: if isParentInFamily(familyId);
        allow update: if isParentOrHelper(familyId);

        // ── Kids' Workplan items (parent-defined, repeatable) ────
        // Parents author + edit a kid's tasks; the whole family can
        // read (kid sees their plan; parent/helper can view it).
        match /workplanItems/{itemId} {
          allow read: if belongsToFamily(familyId);
          allow create, update, delete: if isParentInFamily(familyId);
        }

        // ── Kids' Workplan completions (per-day ticks) ──────────
        // The kid ticks their own day; the parent can also write
        // (corrections, or ticking for a young child). Points on a
        // ticked task are granted server-side (Admin SDK) since a kid
        // can't write awards — so this rule only covers the tick state.
        match /workplanCompletions/{date} {
          allow read: if belongsToFamily(familyId);
          allow create, update, delete: if isParentInFamily(familyId)
            || isThisKid(familyId, childId);
        }

        // ── Kids' Workplan proofs ("proof for points") ──────────
        // One doc per proof-required task per day (id `{date}_{itemId}`).
        // The whole family can READ (the kid sees their own status; the
        // parent sees the review feed). Proof docs are WRITTEN ONLY by
        // the Admin SDK server (/api/workplan/proof + /review), which
        // bypasses these rules — so NO client write is granted here.
        // This is deliberate: it keeps points/award flow server-only,
        // exactly like awards + completions' points handling.
        match /workplanProofs/{proofId} {
          allow read: if belongsToFamily(familyId);
          allow write: if false;
        }
      }

      // ── Ratings ──────────────────────────────────
      match /ratings/{ratingId} {
        allow read: if belongsToFamily(familyId);
        // Parents can rate any kid. Helpers need (a) the kid in their
        // HelperLink.kidIds AND (b) act-tier rating access. Accept
        // any of: composite `kaya:rate`, parent `kaya`, or the legacy
        // `home` key from pre-Kaya-split docs (Aug 2026). Legacy
        // helpers (no HelperLink doc) keep the family-wide allowance
        // until the parent re-adds them.
        allow create: if isParentInFamily(familyId)
          || (helperCanActOnKid(familyId, request.resource.data.childId)
              && (helperCanActOnSub(familyId, 'kaya', 'rate')
                  || helperHasModule(familyId, 'home')))
          || isLegacyHelperWithoutLink(familyId);
      }

      // ── Helpers (per-family scoped credential) ───────────────────
      // One doc per helper at /helpers/{uid}. Parents manage; the
      // helper themselves can read their own doc so the UI can show
      // their scope on the dashboard.
      match /helpers/{helperUid} {
        allow read: if isParentInFamily(familyId) || request.auth.uid == helperUid;
        allow create, update, delete: if isParentInFamily(familyId);

        // ── Workplan items (parent-defined recurring tasks) ────
        // Parents author + edit; the helper themselves can read.
        // Other helpers in the family cannot see another helper's
        // workplan — gated to this helper's own uid.
        match /workplanItems/{itemId} {
          allow read: if isParentInFamily(familyId)
            || request.auth.uid == helperUid;
          allow create, update, delete: if isParentInFamily(familyId);
        }

        // ── Workplan completions (helper-authored per-day state) ─
        // Helper updates their OWN completions (check off items,
        // write EoD note). Parent can also write — useful when the
        // helper forgot or made a mistake. Both can read.
        match /workplanCompletions/{date} {
          allow read: if isParentInFamily(familyId)
            || request.auth.uid == helperUid;
          allow create, update, delete: if isParentInFamily(familyId)
            || request.auth.uid == helperUid;
        }

        // ── Parent feedback notes on this helper (v3 — 2026-05-18)
        // One doc per day. Parents write to leave 👍/😐/👎 + optional
        // note; the helper themselves can READ their own feedback
        // (transparency), but can't write — they shouldn't be able
        // to self-pat. Doc id = YYYY-MM-DD; upserted on each tap.
        match /feedbackNotes/{date} {
          allow read: if isParentInFamily(familyId)
            || request.auth.uid == helperUid;
          allow create, update, delete: if isParentInFamily(familyId);
        }

        // ── Pay check-ins (v3 — 2026-05-19) ─────────────────
        // One doc per day at /payCheckIns/{YYYY-MM-DD}. Helper
        // self-logs hours/days worked; parent approves to count
        // toward the auto-generated salary basic-pay line.
        //   read:   parent + the helper themselves
        //   create: parent (back-fill) + helper (self-log)
        //   update: parent (approve / edit) + helper (re-log)
        //   delete: parent only (reject + remove)
        // The payroll generator reads the approved subset via the
        // parent's session, so listApprovedCheckIns runs under the
        // parent's auth scope.
        match /payCheckIns/{date} {
          allow read: if isParentInFamily(familyId)
            || request.auth.uid == helperUid;
          allow create, update: if isParentInFamily(familyId)
            || request.auth.uid == helperUid;
          allow delete: if isParentInFamily(familyId);
        }
      }

      // ── Performance policy (v3 — 2026-05-18) ──────────────
      // Single config doc per family at /performancePolicy/default
      // holding metric weights + face thresholds + window length +
      // per-helper overrides. Whole family can read (a helper can
      // see how their score is being computed). Parent-only write
      // — only parents tune the rules.
      match /performancePolicy/{policyId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId);
      }

      // ── Awards ───────────────────────────────────
      match /awards/{awardId} {
        allow read: if belongsToFamily(familyId);
        // Parents can create any award. Kids can additionally create
        // 0-point `kudos` awards to a SIBLING (the kid-to-kid
        // appreciation note feature) — only when the family has the
        // feature switched on. The daily-cap throttle is enforced at
        // the app layer in `sendKidKudos` (would otherwise require a
        // counter doc + composite index just for rate-limiting).
        allow create: if isParentInFamily(familyId)
          || (
            // Authed user is a kid in this family.
            getUserProfile().role == 'kid'
            && getUserProfile().familyId == familyId
            // Payload is a kid-authored kudos with the expected shape.
            && request.resource.data.kind == 'kudos'
            && request.resource.data.points == 0
            && request.resource.data.senderRole == 'kid'
            && request.resource.data.awardedBy == request.auth.uid
            // Recipient is some OTHER child in this family (no self-kudos).
            && request.resource.data.childId != getUserProfile().childId
            && exists(/databases/$(database)/documents/families/$(familyId)/children/$(request.resource.data.childId))
            // Family setting must be on. Default false when the field
            // is missing, so families auto-keep the parent-only behaviour
            // until a parent opts in.
            && get(/databases/$(database)/documents/families/$(familyId)).data.pointSystem.kudos.kidToKidEnabled == true
          );
      }

      // ── Meetings ─────────────────────────────────
      match /meetings/{meetingId} {
        allow read: if belongsToFamily(familyId);
        allow create: if belongsToFamily(familyId);
      }

      // ── Rewards ──────────────────────────────────
      match /rewards/{rewardId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId);
      }

      // ── Redemptions ──────────────────────────────
      match /redemptions/{redemptionId} {
        allow read: if belongsToFamily(familyId);
        allow create: if isParentInFamily(familyId);
      }

      // ── Notifications ────────────────────────────
      match /notifications/{notificationId} {
        allow read: if belongsToFamily(familyId);
        allow create: if belongsToFamily(familyId);
        allow update: if belongsToFamily(familyId);
      }

      // ── The Hive · approval requests ─────────────
      // Family-wide queue of pending parent-approval items (cash-out,
      // spend, hp_to_honey conversions). Kids can create their own and
      // cancel their own; only parents can resolve.
      match /approvalRequests/{requestId} {
        allow read: if belongsToFamily(familyId);
        // Kid creates a request for themselves with status='pending'.
        // Parent can also create one (e.g. on behalf of a kid) — same shape.
        allow create: if belongsToFamily(familyId)
          && request.resource.data.status == 'pending'
          && (
            isParentInFamily(familyId)
            || (isThisKid(familyId, request.resource.data.kidId)
                && request.resource.data.createdBy == request.auth.uid)
          );
        // Parents can resolve any request. Kids can flip their OWN pending
        // request to rejected (cancellation).
        allow update: if belongsToFamily(familyId)
          && (
            isParentInFamily(familyId)
            || (
              resource.data.status == 'pending'
              && resource.data.kidId == getUserProfile().childId
              && request.resource.data.status == 'rejected'
            )
          );
      }

      // ── The Hive · per-kid wallet + ledger + goals ───────────
      match /kids/{kidId}/{document=**} {
        // Family members can read each other's Hive sub-tree (parents and
        // helpers see everyone; the kid sees their own). Helpers don't get
        // write access to anything Hive — money is parent ↔ kid only.
        allow read: if belongsToFamily(familyId);
      }

      // Wallet balances are mutated only by callers acting as a parent or
      // as the kid themselves (kid-only writes are gated to the no-op
      // `ensureWallet` path through application logic; the hard guard is
      // that any value-changing write must come from a parent transaction).
      match /kids/{kidId}/wallet/{document} {
        allow write: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
      }

      // Ledger entries: created by the same code paths that mutate the
      // wallet. Parents always; kid only for the auto-paired entries that
      // belong to their own approved/cancelled requests.
      match /kids/{kidId}/hiveTransactions/{txId} {
        allow create: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
        // Ledger entries are immutable once written.
        allow update, delete: if false;
      }

      // Goals: kids manage their own; parents can create or edit any.
      match /kids/{kidId}/goals/{goalId} {
        allow create, update, delete: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
      }

      // Monthly spending plan: kid-set discipline tool. The kid writes
      // their own; parents can also write any kid's (e.g. "let me set up
      // your first plan with you"). Helpers can read but not edit.
      match /kids/{kidId}/monthlyPlans/{monthKey} {
        allow create, update: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
        allow delete: if false;
      }

      // ── Kaya Business · per-kid investments + milestones ──────────
      // Both live under the Hive kid sub-tree, so the
      // `match /kids/{kidId}/{document=**}` read rule above already grants
      // family read. Only write rules are needed here.

      // Junior Investor (simulated) holdings — seeded by the kid and
      // created/updated when a parent approves an investment_buy/sell
      // request (which runs under the parent's auth). Money is virtual in
      // Phase 1; the parent-OK gate is enforced at the app + approval layer.
      match /kids/{kidId}/investments/{symbol} {
        allow create, update, delete: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
      }

      // Unlocked milestones — written by the milestone engine running under
      // whoever logged the triggering sale/cost (parent or the owner kid).
      // Milestones are forever: no client delete.
      match /kids/{kidId}/businessMilestones/{milestoneId} {
        allow create, update: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
        allow delete: if false;
      }

      // ── Kaya Business · businesses + inventory + books ────────────
      // A business is owned by one kid (`ownerId`). Read: the whole family
      // (Parent Console grid + the kid's portfolio). Write: a parent or the
      // owner kid. Helpers are read-only in Phase 1 (they get read via
      // belongsToFamily) — flip on `helperCanActOnModule(.,'business')` here
      // if/when helper bookkeeping is wanted. Closing a business is a status
      // flip to 'closed'; there is no client-side hard delete.
      match /businesses/{businessId} {
        allow read: if belongsToFamily(familyId);
        allow create: if request.resource.data.ownerId != null
          && (isParentInFamily(familyId)
              || isThisKid(familyId, request.resource.data.ownerId));
        allow update: if isParentInFamily(familyId)
          || isThisKid(familyId, resource.data.ownerId);
        allow delete: if false;

        // Inventory — assets + stock. Owner resolved via get() on the parent
        // business doc (one extra read), the same pattern albums→photos uses.
        match /items/{itemId} {
          function bizOwnerId() {
            return get(/databases/$(database)/documents/families/$(familyId)/businesses/$(businessId)).data.ownerId;
          }
          allow read: if belongsToFamily(familyId);
          allow create, update, delete: if isParentInFamily(familyId)
            || isThisKid(familyId, bizOwnerId());
        }

        // The books — sales + costs. Append-only: corrections write a fresh
        // voiding entry, so existing rows are immutable (like hiveTransactions).
        match /ledger/{entryId} {
          function bizOwnerId() {
            return get(/databases/$(database)/documents/families/$(familyId)/businesses/$(businessId)).data.ownerId;
          }
          allow read: if belongsToFamily(familyId);
          allow create: if isParentInFamily(familyId)
            || isThisKid(familyId, bizOwnerId());
          allow update, delete: if false;
        }

        // Daily stock-takes — one doc per day (id = YYYY-MM-DD). Parent or the
        // owner kid record them; never client-deleted (the streak is history).
        match /stockTakes/{date} {
          function bizOwnerId() {
            return get(/databases/$(database)/documents/families/$(familyId)/businesses/$(businessId)).data.ownerId;
          }
          allow read: if belongsToFamily(familyId);
          allow create, update: if isParentInFamily(familyId)
            || isThisKid(familyId, bizOwnerId());
          allow delete: if false;
        }
      }

      // ── Kids Projects (Phase 2 · Cluster B) ───────────────────────
      // Maker-space projects under Kaya Business. Read: the whole family
      // (so siblings/collaborators + parents see them). Write: a parent or
      // the owner kid. No client hard-delete (archive via status instead).
      match /projects/{projectId} {
        allow read: if belongsToFamily(familyId);
        allow create: if request.resource.data.ownerId != null
          && (isParentInFamily(familyId)
              || isThisKid(familyId, request.resource.data.ownerId));
        allow update: if isParentInFamily(familyId)
          || isThisKid(familyId, resource.data.ownerId);
        allow delete: if false;
      }

      // ── Messaging · family group + direct threads ─────────────────
      // Threads carry `memberUids`. A member can read/write their own
      // threads; a parent additionally gets oversight READ on any thread
      // (it's a family app) and may update read-state — but only members
      // can POST a message (parents observe kid↔kid DMs, they don't
      // impersonate). Messages are append-only in v1 (moderation later).
      match /threads/{threadId} {
        allow read: if isSignedIn()
          && ((request.auth.uid in resource.data.memberUids) || isParentInFamily(familyId));
        // Creator must be a family member and include themselves.
        allow create: if belongsToFamily(familyId)
          && (request.auth.uid in request.resource.data.memberUids);
        // Members update on send (lastAt/reads) + re-merge membership;
        // a parent may also update (oversight mark-read).
        allow update: if isSignedIn()
          && ((request.auth.uid in resource.data.memberUids) || isParentInFamily(familyId));
        allow delete: if false;

        match /messages/{messageId} {
          function thread() {
            return get(/databases/$(database)/documents/families/$(familyId)/threads/$(threadId)).data;
          }
          allow read: if isSignedIn()
            && ((request.auth.uid in thread().memberUids) || isParentInFamily(familyId));
          // Only a thread member can post, and only as themselves.
          allow create: if (request.auth.uid in thread().memberUids)
            && request.resource.data.senderUid == request.auth.uid;
          allow update, delete: if false;  // append-only
        }
      }

      // ── The Pantry · staples ─────────────────────────────────────
      // Master list of recurring household items. Parents + helpers
      // (with the `household` module) edit; kids read only (suggest
      // mode arrives in Phase 1B). Legacy helpers without a HelperLink
      // doc keep the old family-wide allowance.
      match /staples/{stapleId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'staples')
          || isLegacyHelperWithoutLink(familyId);
      }

      // ── Suppliers (Soko + future Roster) ──────────────────────────
      // Single source of truth shared with The Roster directory. The
      // Pantry view filters by `categories` array-contains 'soko'; the
      // Roster shows all entries. Gated by `household` module.
      match /suppliers/{supplierId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'suppliers')
          || isLegacyHelperWithoutLink(familyId);
      }

      // ── The Pantry · utilities ───────────────────────────────────
      // Recurring household bills + helper salaries (power, water,
      // internet, TV, security, rent…). Gated by `household` module.
      // Rolls up — alongside staples — into the Budget.
      match /utilities/{utilityId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'utilities')
          || isLegacyHelperWithoutLink(familyId);

        // Payment ledger — one doc per period the bill was paid.
        // Same Household → Utilities sub-grant covers payments.
        match /payments/{paymentId} {
          allow read: if belongsToFamily(familyId);
          allow create, update, delete: if isParentInFamily(familyId)
            || helperCanActOnSub(familyId, 'household', 'utilities')
            || isLegacyHelperWithoutLink(familyId);
        }
      }

      // ── Catalog overlay ──────────────────────────────────────────
      // Per-family edits + additions layered on the built-in product
      // catalog (see lib/pantryCatalog.ts). Gated by `household` module.
      match /catalogItems/{itemId} {
        allow read: if belongsToFamily(familyId);
        // Catalog items feed the grocery list — gate by the `list` sub.
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'list')
          || isLegacyHelperWithoutLink(familyId);
      }

      // ── Custom dishes ────────────────────────────────────────────
      // Per-family custom dishes layered on the built-in foods catalog
      // (see lib/pantryCatalog.ts). Gated by `household` module.
      match /catalogFoods/{foodId} {
        allow read: if belongsToFamily(familyId);
        // Custom dishes feed meal planning — gate by the `meals` sub.
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'meals')
          || isLegacyHelperWithoutLink(familyId);
      }

      // ── Grocery lists ────────────────────────────────────────────
      // Active runs (one per week, by convention). Gated by `household`
      // module. Phase 1B will let kids suggest items via a separate
      // `suggestions` subcollection that doesn't touch the list directly.
      match /groceryLists/{listId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'list')
          || isLegacyHelperWithoutLink(familyId);
      }

      // ── Purchase requests (Household → Purchase v1) ──────────────
      // The request → approve → reconcile loop that actually debits the
      // Household budget. Coexists with `groceryLists` for now. Gated by
      // a new `household/purchase` sub-grant so a Gardener can be given
      // External-only access later without inheriting Pantry Purchase
      // permission. Parents are always allowed; helpers need the sub.
      //
      // v1 keeps the rule simple: any signed-in family member with the
      // grant can write the whole doc. Approval semantics (status
      // transitions, "Both parents must approve") are enforced in the
      // UI for now and will tighten into rule-level validators when
      // step 2 (Approval mode) lands.
      // ── Utility meters (Household → Utility) ────────────────────
      // The family's tracked meters (electric / water / gas / internet /
      // etc.) — one doc per meter. Tim-family has 5 electric meters; the
      // collection scales. Gated by the household/utility sub-grant for
      // helpers; parents unconstrained. Each Utility PurchaseRequest
      // pins to a meter via `request.meterId`.
      match /utilityMeters/{meterId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'utility')
          || isLegacyHelperWithoutLink(familyId);
      }

      // ── Vehicles (Household → Drivers) ─────────────────────────
      // The family's vehicles (sedan / SUV / pickup / motorbike /
      // tuk-tuk / etc.) — one doc per vehicle. Each Drivers
      // PurchaseRequest pins to a vehicle via `request.vehicleId`
      // so workshop bills attribute to the actual car.
      // Same shape as utilityMeters. Gated by household/drivers
      // sub-grant for helpers; parents unconstrained. When Kaya
      // Wealth ships, this collection will be mirrored from the KW
      // asset registry — the path stays stable so call sites don't
      // change.
      match /vehicles/{vehicleId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'drivers')
          || isLegacyHelperWithoutLink(familyId);
      }

      // ════════════════════════════════════════════════════════════
      // Kaya Pulse (2026-05-22) — finance/task module folded into the
      // app. Trackables + templates are parent-managed config. Readings
      // are an immutable, append-only ledger (corrections = new docs).
      // Helpers act when granted the 'pulse' module; a kid acts on their
      // own tasks/readings. Crons write via the Admin SDK (bypass rules).
      // ════════════════════════════════════════════════════════════

      // Non-meter trackables (fuel / generator / odometer / custom).
      // Utility trackables reuse /utilityMeters above. Config = parent.
      match /trackables/{trackableId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId);
      }

      // Immutable consumption ledger. Anyone who can log — a parent, a
      // pulse-granted helper, or the kid logging their OWN reading — may
      // CREATE; nobody may edit or delete (a correction is a new doc
      // referencing the original via correctionOf).
      match /readings/{readingId} {
        allow read: if belongsToFamily(familyId);
        allow create: if isParentInFamily(familyId)
          || helperCanActOnModule(familyId, 'pulse')
          || isThisKid(familyId, request.resource.data.capturedBy);
        allow update, delete: if false;
      }

      // Task templates — parent-managed config (admin-only writes).
      match /pulseTemplates/{templateId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId);
      }

      // Daily task instances. Created by the generator cron (Admin SDK)
      // or a parent; the OWNER flips their own task to logged/closed, and
      // a parent can override any task.
      match /pulseTasks/{taskId} {
        allow read: if belongsToFamily(familyId);
        allow create: if isParentInFamily(familyId);
        allow update: if isParentInFamily(familyId)
          || isThisKid(familyId, resource.data.ownerId)
          || (helperCanActOnModule(familyId, 'pulse') && resource.data.ownerId == request.auth.uid);
        allow delete: if isParentInFamily(familyId);
      }

      // Savings → Wealth pending-deposit pool (one doc per month). Created
      // by the month-end cron; parents approve/deposit. Never deleted.
      match /wealthPool/{monthKey} {
        allow read: if belongsToFamily(familyId);
        allow create, update: if isParentInFamily(familyId);
        allow delete: if false;
      }

      // Frozen month-end budget aggregate (cron-written; parent fallback).
      match /budgetSnapshots/{monthKey} {
        allow read: if belongsToFamily(familyId);
        allow create, update: if isParentInFamily(familyId);
        allow delete: if false;
      }

      // Anomaly alerts — created as part of logging; acknowledged by a
      // parent. Never deleted (audit trail).
      match /pulseAlerts/{alertId} {
        allow read: if belongsToFamily(familyId);
        allow create: if belongsToFamily(familyId);
        allow update: if isParentInFamily(familyId);
        allow delete: if false;
      }

      // Pulse-scoped streak per owner (doc id = Child id or helper uid).
      // The owner updates their own; a parent updates any.
      match /pulseProfiles/{ownerId} {
        allow read: if belongsToFamily(familyId);
        allow create, update: if isParentInFamily(familyId)
          || isThisKid(familyId, ownerId)
          || (helperCanActOnModule(familyId, 'pulse') && ownerId == request.auth.uid);
        allow delete: if false;
      }

      // ── Counters (2026-05-18) ──────────────────────────────────
      // Per-family monotonic counters for things like the
      // per-module request sequence (`PNT-0042`). One doc per
      // counter; doc ids follow the pattern `purchaseRequests-{module}`.
      // Anyone who can create a request needs to read+increment the
      // matching counter doc atomically, so the write scope mirrors
      // the purchaseRequests create scope (parents + any module-
      // grant helper + payroll-self via the relevant module rules).
      // Reads are open to the whole family — counters are
      // non-sensitive ("we've made N requests this year") + the
      // detail page may want to display the rendered serial pill.
      match /counters/{counterId} {
        allow read: if belongsToFamily(familyId);
        allow create, update: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'purchase')
          || helperCanActOnSub(familyId, 'household', 'outdoor')
          || helperCanActOnSub(familyId, 'household', 'drivers')
          || helperCanActOnSub(familyId, 'household', 'utility')
          || isLegacyHelperWithoutLink(familyId);
        // No delete — counters should never be reset by users.
      }

      match /purchaseRequests/{requestId} {
        // ── Read ──
        // Non-payroll requests: any family member (today's behaviour).
        // Payroll requests: parents see all; helpers see ONLY their
        // own (where `helperUid == auth.uid`). Self-service privacy
        // per the v3 design (2026-05-18, Decision B locked in).
        allow read: if belongsToFamily(familyId)
          && (
            resource.data.module != 'payroll'
            || isParentInFamily(familyId)
            || resource.data.helperUid == request.auth.uid
          );

        // ── Create ──
        // Parents can create anything. Helpers with the relevant
        // sub-grant can create non-payroll requests in their module.
        // Payroll create is self-service ONLY — a helper can create
        // a payroll request, but it MUST pin their own UID (no
        // creating-on-behalf-of-others). Parents can create payroll
        // requests on behalf of any helper.
        allow create: if isParentInFamily(familyId)
          || (
            request.resource.data.module == 'payroll'
            && request.resource.data.helperUid == request.auth.uid
          )
          || (
            request.resource.data.module != 'payroll'
            && (
              helperCanActOnSub(familyId, 'household', 'purchase')
              || helperCanActOnSub(familyId, 'household', 'outdoor')
              || helperCanActOnSub(familyId, 'household', 'drivers')
              || helperCanActOnSub(familyId, 'household', 'utility')
              || isLegacyHelperWithoutLink(familyId)
            )
          );

        // ── Update + Delete ──
        // Parents unconstrained. Helpers can update non-payroll
        // requests they have grant for (existing rule), OR their own
        // payroll requests (pinned by helperUid). Mirrors read scope.
        allow update, delete: if isParentInFamily(familyId)
          || (
            resource.data.module == 'payroll'
            && resource.data.helperUid == request.auth.uid
          )
          || (
            resource.data.module != 'payroll'
            && (
              helperCanActOnSub(familyId, 'household', 'purchase')
              || helperCanActOnSub(familyId, 'household', 'outdoor')
              || helperCanActOnSub(familyId, 'household', 'drivers')
              || helperCanActOnSub(familyId, 'household', 'utility')
              || isLegacyHelperWithoutLink(familyId)
            )
          );
      }

      // ── Purchase request TEMPLATES (2026-05-18) ─────────────────
      // Auto-saved snapshots of approved/rejected baskets, so the
      // family can re-issue a similar shop in one tap. Doc id is
      // deterministic (module + slugified name) so the latest snapshot
      // upserts the prior one.
      //
      // Same access shape as purchaseRequests above EXCEPT payroll
      // is NOT a template-relevant module (helpers self-service
      // their pay; no template reuse pattern). Parents + module-
      // grant helpers can write; everyone in the family can read
      // (browsing templates is no riskier than browsing past
      // requests, which is already allowed).
      match /purchaseTemplates/{templateId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentInFamily(familyId)
          || helperCanActOnSub(familyId, 'household', 'purchase')
          || helperCanActOnSub(familyId, 'household', 'outdoor')
          || helperCanActOnSub(familyId, 'household', 'drivers')
          || helperCanActOnSub(familyId, 'household', 'utility')
          || isLegacyHelperWithoutLink(familyId);
      }

      // ── Moments · Keepsake Albums ────────────────────────────────
      // Family photo repository. Each album has its own access list;
      // sub-albums inherit-then-narrow (their accessList must be a
      // subset of the parent's effective audience). Photos live in
      // Storage at families/{f}/albums/{a}/{p}/{size}.jpg.
      //
      // Access enforcement: parents see everything in their family
      // (they own the data). Members + kids see albums where
      // accessMode == 'all_family' OR their uid is in accessList.
      // Photo-level reads gate on the parent album's access, so
      // restricted-album photos cannot be enumerated by guessing IDs.
      match /albums/{albumId} {
        // Reusable inline visibility check for THIS album doc.
        function canViewThisAlbum() {
          let a = resource.data;
          return belongsToFamily(familyId) && (
            isParentInFamily(familyId)
            || a.accessMode == 'all_family'
            || (a.accessList is list && request.auth.uid in a.accessList)
          );
        }

        allow read: if canViewThisAlbum();

        // Create: any family member can create an album. The reserve
        // step writes pending=true with minimal fields; finalize
        // patches the rest. For sub-albums we verify the parent
        // exists (a stronger inheritance check at write-time is in
        // updateAlbumAccess + the picker UI). Helpers additionally
        // need the `moments` module granted on their HelperLink.
        allow create: if belongsToFamily(familyId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.accessMode in ['all_family', 'custom']
          && (getUserProfile().role != 'helper'
              || helperHasModule(familyId, 'moments')
              || isLegacyHelperWithoutLink(familyId))
          && (
            request.resource.data.parentAlbumId == null
            || exists(/databases/$(database)/documents/families/$(familyId)/albums/$(request.resource.data.parentAlbumId))
          );

        // Update: parents + the album's author can change anything.
        // Other family members can only bump the photoCount counter
        // (paired with a photo create/delete under their auth) — they
        // can't rename, change access, or reassign the cover.
        allow update: if canViewThisAlbum() && (
          isParentInFamily(familyId)
          || resource.data.createdBy == request.auth.uid
          || (
            request.resource.data.accessMode == resource.data.accessMode
            && request.resource.data.accessList == resource.data.accessList
            && request.resource.data.name == resource.data.name
            && request.resource.data.parentAlbumId == resource.data.parentAlbumId
          )
        );

        allow delete: if belongsToFamily(familyId)
          && (resource.data.createdBy == request.auth.uid
              || isParentInFamily(familyId));

        // ── Album photos ─────────────────────────────────────────
        match /photos/{photoId} {
          // Gate every photo op on the parent album's visibility.
          // One extra Firestore read per op — acceptable for the
          // privacy guarantee it gives sub-album restrictions.
          function canViewParentAlbum() {
            let a = get(/databases/$(database)/documents/families/$(familyId)/albums/$(albumId)).data;
            return belongsToFamily(familyId) && (
              isParentInFamily(familyId)
              || a.accessMode == 'all_family'
              || (a.accessList is list && request.auth.uid in a.accessList)
            );
          }

          allow read: if canViewParentAlbum();
          allow create: if canViewParentAlbum()
            && request.resource.data.uploadedBy == request.auth.uid
            && (getUserProfile().role != 'helper'
                || helperHasModule(familyId, 'moments')
                || isLegacyHelperWithoutLink(familyId));
          allow delete: if belongsToFamily(familyId)
            && (resource.data.uploadedBy == request.auth.uid
                || isParentInFamily(familyId));
        }
      }

      // ── Moments · event tags (2026-05-23) ───────────────────────
      // Per-family "When / What" chips with usage counts so the picker
      // can float frequent ones forward + keep customs. Any family member
      // can read + upsert (kids post moments too); count bumps via
      // increment() on the same doc.
      match /eventTags/{tagId} {
        allow read: if belongsToFamily(familyId);
        allow create, update: if belongsToFamily(familyId);
      }

      // ── Dine Out · venues (2026-05-23) ──────────────────────────
      // Per-family record of places you eat out (rating, Diamond,
      // highlights, typical spend). Family members read; only parents
      // write (parents rate venues; helpers don't).
      match /venues/{venueId} {
        allow read: if belongsToFamily(familyId);
        allow create, update: if isParentInFamily(familyId);
      }

      // ── Moments · family photo feed ──────────────────────────────
      // Posts carry photos uploaded to Firebase Storage at
      // families/{f}/posts/{p}/{photoId}/{size}.jpg (see storage.rules).
      // Every family member (parent, helper, kid) can post and react —
      // the feed is the social glue, so kids participating is the
      // point. Only the author or a parent can delete a post or a
      // comment. `visibility` is in the schema so a later release can
      // ship 'network' without a migration; today the UI only writes
      // 'family' and rules enforce that.
      match /posts/{postId} {
        allow read: if belongsToFamily(familyId);
        allow create: if belongsToFamily(familyId)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.visibility in ['family', 'network']
          && (getUserProfile().role != 'helper'
              || helperHasModule(familyId, 'moments')
              || isLegacyHelperWithoutLink(familyId));
        // Updates: the author can edit caption / photos / kid tags;
        // any member can bump the reaction + comment counters via the
        // toggleReaction / addComment batched writes. To keep things
        // simple we allow any belongsToFamily update — the
        // reaction-counter writes always come paired with a sub-doc
        // create/delete that requires the same auth, so a malicious
        // unrelated update would have to be hand-crafted.
        allow update: if belongsToFamily(familyId);
        allow delete: if belongsToFamily(familyId)
          && (resource.data.authorUid == request.auth.uid
              || isParentInFamily(familyId));

        match /reactions/{reactionId} {
          allow read: if belongsToFamily(familyId);
          allow create: if belongsToFamily(familyId)
            && request.resource.data.byUid == request.auth.uid;
          allow delete: if belongsToFamily(familyId)
            && resource.data.byUid == request.auth.uid;
        }

        match /comments/{commentId} {
          allow read: if belongsToFamily(familyId);
          allow create: if belongsToFamily(familyId)
            && request.resource.data.byUid == request.auth.uid;
          allow delete: if belongsToFamily(familyId)
            && (resource.data.byUid == request.auth.uid
                || isParentInFamily(familyId));
        }
      }
    }

    // ── Kaya Business · market quotes (global, server-written) ───────
    // Cached real stock/fund prices for the curated Junior Investor menu.
    // Not family-specific. Any signed-in user can read; only the server
    // (admin SDK / scheduled job) writes — clients never set prices.
    match /marketQuotes/{symbol} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Closed-beta access control (2026-05-24) ──────────────────────
    // Top-level (cross-family) collections behind the invite-only launch
    // + the operator console at /admin. Doc ids for allowlist/operators
    // are the lowercased email.
    //   config/beta   — the two runtime switches; world-readable so the
    //                   pre-auth login screen can decide what to show.
    //   allowlist/{e} — approved early-access emails.
    //   operators/{e} — Kaya staff who can open /admin.
    //   waitlist/{e}  — interest registrations; written server-side only
    //                   (/api/waitlist via Admin SDK), read by operators.
    match /config/beta {
      allow read: if true;
      allow write: if isOperator();
    }
    match /allowlist/{emailKey} {
      allow read: if isSignedIn() && (isOperator() || emailKey == callerEmail());
      allow write: if isOperator();
    }
    match /operators/{emailKey} {
      allow read: if isSignedIn() && (isOperator() || emailKey == callerEmail());
      allow create, update: if isOperator();
      // The owner can't be removed from the client.
      allow delete: if isOperator()
        && get(/databases/$(database)/documents/operators/$(emailKey)).data.role != 'owner';
    }
    match /waitlist/{entryId} {
      allow read: if isOperator();
      allow write: if false;
    }

    // ── Kaya Sparks · ideas & help community (2026-05-26) ────────────
    // Top-level, cross-family. CLIENTS NEVER READ THIS DIRECTLY — the
    // anonymity model relies on /api/sparks/* stripping author identity
    // before the wire. Operators can read raw docs for moderation.
    //   sparks/{sparkId}              — the post itself (full author info)
    //     /comments/{commentId}        — threaded comments
    //     /upvotes/{uid}               — one doc per voter (uid keyed)
    //   config/sparks                  — global settings (roadmap toggle,
    //                                    reward size, moderation mode…).
    //                                    Readable by any signed-in user so
    //                                    UI can react (e.g. show/hide the
    //                                    roadmap strip) without a round-
    //                                    trip through /api on every page.
    match /sparks/{sparkId} {
      allow read: if isOperator();
      allow write: if false;
      match /comments/{commentId} {
        allow read: if isOperator();
        allow write: if false;
      }
      match /upvotes/{voterUid} {
        allow read: if isOperator();
        allow write: if false;
      }
    }
    match /config/sparks {
      allow read: if isSignedIn();
      allow write: if isOperator();
    }

    // ── Kaya Tiers · subscription plan configs (2026-05-26) ─────────
    // /config/tiers/plans/{tierId} — per-tier overrides on top of
    // DEFAULT_TIERS in lib/tiers.ts. Any signed-in user can read (so
    // the /subscription page + module-gating UI can render without an
    // /api round-trip on every navigation); only operators write.
    match /config/tiers/plans/{tierId} {
      allow read: if isSignedIn();
      allow write: if isOperator();
    }
  }
}
