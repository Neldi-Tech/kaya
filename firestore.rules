rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToFamily(familyId) {
      return isSignedIn() && getUserProfile().familyId == familyId;
    }

    function isParentInFamily(familyId) {
      return belongsToFamily(familyId) && getUserProfile().role == 'parent';
    }

    function isParentOrHelper(familyId) {
      let profile = getUserProfile();
      return belongsToFamily(familyId) && (profile.role == 'parent' || profile.role == 'helper');
    }

    // True if the calling user is the kid linked to `kidId` in `familyId`.
    // Helpers and parents return false here — use `isParentInFamily` /
    // `isParentOrHelper` for those branches.
    function isThisKid(familyId, kidId) {
      let profile = getUserProfile();
      return belongsToFamily(familyId)
        && profile.role == 'kid'
        && profile.childId == kidId;
    }

    // ── Users ──────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile, OR any profile attached to
      // the same family. The cross-family lookup is what makes the
      // @mention picker, rating/award notification routing, and family
      // tree work — without it `getFamilyMembers` silently fails and
      // none of those features can find anyone besides the caller.
      // The `get()` costs one extra read per query but is bounded:
      // the picker only loads it once per session.
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || (
          resource.data.familyId != null
          && resource.data.familyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId
        )
      );
      // Users can create their own profile (during onboarding)
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Users can update their own profile
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Families ───────────────────────────────────
    match /families/{familyId} {
      // Family members can read
      allow read: if belongsToFamily(familyId);
      // Any signed-in user can create a family (during onboarding)
      allow create: if isSignedIn();
      // Only parents can update family settings
      allow update: if isParentInFamily(familyId);

      // Allow reading family by invite code (for joining)
      allow list: if isSignedIn();

      // ── Children ─────────────────────────────────
      match /children/{childId} {
        allow read: if belongsToFamily(familyId);
        allow create: if isParentInFamily(familyId);
        allow update: if isParentOrHelper(familyId);
      }

      // ── Ratings ──────────────────────────────────
      match /ratings/{ratingId} {
        allow read: if belongsToFamily(familyId);
        // Parents and helpers can rate
        allow create: if isParentOrHelper(familyId);
      }

      // ── Awards ───────────────────────────────────
      match /awards/{awardId} {
        allow read: if belongsToFamily(familyId);
        // Only parents can award points
        allow create: if isParentInFamily(familyId);
      }

      // ── Meetings ─────────────────────────────────
      match /meetings/{meetingId} {
        allow read: if belongsToFamily(familyId);
        allow create: if belongsToFamily(familyId);
      }

      // ── Rewards ──────────────────────────────────
      match /rewards/{rewardId} {
        allow read: if belongsToFamily(familyId);
        allow create, update: if isParentInFamily(familyId);
      }

      // ── Redemptions ──────────────────────────────
      match /redemptions/{redemptionId} {
        allow read: if belongsToFamily(familyId);
        allow create: if isParentInFamily(familyId);
      }

      // ── Notifications ────────────────────────────
      match /notifications/{notificationId} {
        allow read: if belongsToFamily(familyId);
        allow create: if belongsToFamily(familyId);
        allow update: if belongsToFamily(familyId);
      }

      // ── The Hive · approval requests ─────────────
      // Family-wide queue of pending parent-approval items (cash-out,
      // spend, hp_to_honey conversions). Kids can create their own and
      // cancel their own; only parents can resolve.
      match /approvalRequests/{requestId} {
        allow read: if belongsToFamily(familyId);
        // Kid creates a request for themselves with status='pending'.
        // Parent can also create one (e.g. on behalf of a kid) — same shape.
        allow create: if belongsToFamily(familyId)
          && request.resource.data.status == 'pending'
          && (
            isParentInFamily(familyId)
            || (isThisKid(familyId, request.resource.data.kidId)
                && request.resource.data.createdBy == request.auth.uid)
          );
        // Parents can resolve any request. Kids can flip their OWN pending
        // request to rejected (cancellation).
        allow update: if belongsToFamily(familyId)
          && (
            isParentInFamily(familyId)
            || (
              resource.data.status == 'pending'
              && resource.data.kidId == getUserProfile().childId
              && request.resource.data.status == 'rejected'
            )
          );
      }

      // ── The Hive · per-kid wallet + ledger + goals ───────────
      match /kids/{kidId}/{document=**} {
        // Family members can read each other's Hive sub-tree (parents and
        // helpers see everyone; the kid sees their own). Helpers don't get
        // write access to anything Hive — money is parent ↔ kid only.
        allow read: if belongsToFamily(familyId);
      }

      // Wallet balances are mutated only by callers acting as a parent or
      // as the kid themselves (kid-only writes are gated to the no-op
      // `ensureWallet` path through application logic; the hard guard is
      // that any value-changing write must come from a parent transaction).
      match /kids/{kidId}/wallet/{document} {
        allow write: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
      }

      // Ledger entries: created by the same code paths that mutate the
      // wallet. Parents always; kid only for the auto-paired entries that
      // belong to their own approved/cancelled requests.
      match /kids/{kidId}/hiveTransactions/{txId} {
        allow create: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
        // Ledger entries are immutable once written.
        allow update, delete: if false;
      }

      // Goals: kids manage their own; parents can create or edit any.
      match /kids/{kidId}/goals/{goalId} {
        allow create, update, delete: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
      }

      // Monthly spending plan: kid-set discipline tool. The kid writes
      // their own; parents can also write any kid's (e.g. "let me set up
      // your first plan with you"). Helpers can read but not edit.
      match /kids/{kidId}/monthlyPlans/{monthKey} {
        allow create, update: if isParentInFamily(familyId)
          || isThisKid(familyId, kidId);
        allow delete: if false;
      }

      // ── The Pantry · staples ─────────────────────────────────────
      // Master list of recurring household items. Parents + helpers
      // edit; kids read only (suggest mode arrives in Phase 1B).
      match /staples/{stapleId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentOrHelper(familyId);
      }

      // ── Suppliers (Soko + future Roster) ──────────────────────────
      // Single source of truth shared with The Roster directory. The
      // Pantry view filters by `categories` array-contains 'soko'; the
      // Roster shows all entries.
      match /suppliers/{supplierId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentOrHelper(familyId);
      }

      // ── The Pantry · utilities ───────────────────────────────────
      // Recurring household bills + helper salaries (power, water,
      // internet, TV, security, rent…). Parents + helpers edit; kids
      // read only. Rolls up — alongside staples — into the Budget.
      match /utilities/{utilityId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentOrHelper(familyId);

        // Payment ledger — one doc per period the bill was paid.
        // Parents + helpers can record payments; everyone in the
        // family can read the history.
        match /payments/{paymentId} {
          allow read: if belongsToFamily(familyId);
          allow create, update, delete: if isParentOrHelper(familyId);
        }
      }

      // ── Catalog overlay ──────────────────────────────────────────
      // Per-family edits + additions layered on the built-in product
      // catalog (see lib/pantryCatalog.ts). Parents + helpers edit;
      // kids read only.
      match /catalogItems/{itemId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentOrHelper(familyId);
      }

      // ── Custom dishes ────────────────────────────────────────────
      // Per-family custom dishes layered on the built-in foods catalog
      // (see lib/pantryCatalog.ts). Parents + helpers edit; kids read.
      match /catalogFoods/{foodId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentOrHelper(familyId);
      }

      // ── Grocery lists ────────────────────────────────────────────
      // Active runs (one per week, by convention). Parents + helpers
      // edit; kids read only. Phase 1B will let kids suggest items via
      // a separate `suggestions` subcollection that doesn't touch the
      // list directly.
      match /groceryLists/{listId} {
        allow read: if belongsToFamily(familyId);
        allow create, update, delete: if isParentOrHelper(familyId);
      }

      // ── Moments · Keepsake Albums ────────────────────────────────
      // Family photo repository. Each album has its own access list;
      // sub-albums inherit-then-narrow (their accessList must be a
      // subset of the parent's effective audience). Photos live in
      // Storage at families/{f}/albums/{a}/{p}/{size}.jpg.
      //
      // Access enforcement: parents see everything in their family
      // (they own the data). Members + kids see albums where
      // accessMode == 'all_family' OR their uid is in accessList.
      // Photo-level reads gate on the parent album's access, so
      // restricted-album photos cannot be enumerated by guessing IDs.
      match /albums/{albumId} {
        // Reusable inline visibility check for THIS album doc.
        function canViewThisAlbum() {
          let a = resource.data;
          return belongsToFamily(familyId) && (
            isParentInFamily(familyId)
            || a.accessMode == 'all_family'
            || (a.accessList is list && request.auth.uid in a.accessList)
          );
        }

        allow read: if canViewThisAlbum();

        // Create: any family member can create an album. The reserve
        // step writes pending=true with minimal fields; finalize
        // patches the rest. For sub-albums we verify the parent
        // exists (a stronger inheritance check at write-time is in
        // updateAlbumAccess + the picker UI).
        allow create: if belongsToFamily(familyId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.accessMode in ['all_family', 'custom']
          && (
            request.resource.data.parentAlbumId == null
            || exists(/databases/$(database)/documents/families/$(familyId)/albums/$(request.resource.data.parentAlbumId))
          );

        // Update: parents + the album's author can change anything.
        // Other family members can only bump the photoCount counter
        // (paired with a photo create/delete under their auth) — they
        // can't rename, change access, or reassign the cover.
        allow update: if canViewThisAlbum() && (
          isParentInFamily(familyId)
          || resource.data.createdBy == request.auth.uid
          || (
            request.resource.data.accessMode == resource.data.accessMode
            && request.resource.data.accessList == resource.data.accessList
            && request.resource.data.name == resource.data.name
            && request.resource.data.parentAlbumId == resource.data.parentAlbumId
          )
        );

        allow delete: if belongsToFamily(familyId)
          && (resource.data.createdBy == request.auth.uid
              || isParentInFamily(familyId));

        // ── Album photos ─────────────────────────────────────────
        match /photos/{photoId} {
          // Gate every photo op on the parent album's visibility.
          // One extra Firestore read per op — acceptable for the
          // privacy guarantee it gives sub-album restrictions.
          function canViewParentAlbum() {
            let a = get(/databases/$(database)/documents/families/$(familyId)/albums/$(albumId)).data;
            return belongsToFamily(familyId) && (
              isParentInFamily(familyId)
              || a.accessMode == 'all_family'
              || (a.accessList is list && request.auth.uid in a.accessList)
            );
          }

          allow read: if canViewParentAlbum();
          allow create: if canViewParentAlbum()
            && request.resource.data.uploadedBy == request.auth.uid;
          allow delete: if belongsToFamily(familyId)
            && (resource.data.uploadedBy == request.auth.uid
                || isParentInFamily(familyId));
        }
      }

      // ── Moments · family photo feed ──────────────────────────────
      // Posts carry photos uploaded to Firebase Storage at
      // families/{f}/posts/{p}/{photoId}/{size}.jpg (see storage.rules).
      // Every family member (parent, helper, kid) can post and react —
      // the feed is the social glue, so kids participating is the
      // point. Only the author or a parent can delete a post or a
      // comment. `visibility` is in the schema so a later release can
      // ship 'network' without a migration; today the UI only writes
      // 'family' and rules enforce that.
      match /posts/{postId} {
        allow read: if belongsToFamily(familyId);
        allow create: if belongsToFamily(familyId)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.visibility in ['family', 'network'];
        // Updates: the author can edit caption / photos / kid tags;
        // any member can bump the reaction + comment counters via the
        // toggleReaction / addComment batched writes. To keep things
        // simple we allow any belongsToFamily update — the
        // reaction-counter writes always come paired with a sub-doc
        // create/delete that requires the same auth, so a malicious
        // unrelated update would have to be hand-crafted.
        allow update: if belongsToFamily(familyId);
        allow delete: if belongsToFamily(familyId)
          && (resource.data.authorUid == request.auth.uid
              || isParentInFamily(familyId));

        match /reactions/{reactionId} {
          allow read: if belongsToFamily(familyId);
          allow create: if belongsToFamily(familyId)
            && request.resource.data.byUid == request.auth.uid;
          allow delete: if belongsToFamily(familyId)
            && resource.data.byUid == request.auth.uid;
        }

        match /comments/{commentId} {
          allow read: if belongsToFamily(familyId);
          allow create: if belongsToFamily(familyId)
            && request.resource.data.byUid == request.auth.uid;
          allow delete: if belongsToFamily(familyId)
            && (resource.data.byUid == request.auth.uid
                || isParentInFamily(familyId));
        }
      }
    }
  }
}
